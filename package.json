{
  "name": "atfi-memnu-app",
  "version": "2.13.4",
  "description": "Citation Search and Verification App",
  "author": "temasictfic",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:backend": "pwsh -ExecutionPolicy Bypass -File ./scripts/build-backend.ps1",
    "release:tag": "pwsh -ExecutionPolicy Bypass -File ./scripts/release.ps1",
    "optimize:assets": "node scripts/optimize-assets.mjs",
    "pack": "npm run build:backend && npm run build && electron-builder --dir",
    "dist:win": "npm run build:backend && npm run build && electron-builder --win",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "electron-updater": "^6.8.5",
    "i18next": "^26.0.10",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.7",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.9.1",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.14",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.1"
  }
}
